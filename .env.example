# Discord Bot Configuration
# Replace these values with your actual Discord bot credentials

# Your Discord Bot Token
# Get it from: https://discord.com/developers/applications
DISCORD_TOKEN=YOUR-TOKEN-HERE

# Your Discord User ID (for owner-only commands)
# To find your ID: Enable Developer Mode in Discord and right-click your name
OWNER_ID=0

# (Optional) Discord Application ID
# Found in Discord Developer Portal
APPLICATION_ID=0

# (Optional) Web Server Port
# Default: 5000
WEB_PORT=5000

# (Optional) Web Server Debug Mode
# Default: false
DEBUG=false

# (Optional) Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# (Optional) Web dashboard admin API token (X-Admin-Token header)
WEB_ADMIN_TOKEN=
